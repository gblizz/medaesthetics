generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  PRACTICE_OWNER
  PROVIDER
  FRONT_DESK
  CLIENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  STRIPE_CARD
  CASH
  CHECK
  LOYALTY_POINTS
  PACKAGE_CREDIT
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum FormFieldType {
  TEXT
  TEXTAREA
  SELECT
  CHECKBOX
  RADIO
  DATE
  PHONE
  EMAIL
  SIGNATURE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum CampaignChannel {
  EMAIL
  SMS
}

// ─────────────────────────────────────────────
// MULTI-TENANCY: PRACTICE (TOP-LEVEL TENANT)
// ─────────────────────────────────────────────

model Practice {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  primaryColor   String?  @default("#6366f1")
  secondaryColor String?
  accentColor    String?
  titleFont      String?  @default("Cormorant Garamond")
  headerFont     String?  @default("Montserrat")
  bodyFont       String?  @default("Inter")
  phone       String?
  email       String?
  website     String?
  addressLine1 String?
  addressLine2 String?
  city        String?
  state       String?
  zip         String?
  timezone    String   @default("America/New_York")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subscription
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionTier     SubscriptionTier @default(STARTER)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?

  // Relations
  providers           Provider[]
  staffMembers        StaffMember[]
  clients             Client[]
  services            Service[]
  locations           Location[]
  appointments        Appointment[]
  invoices            Invoice[]
  inventoryItems      InventoryItem[]
  consentTemplates    ConsentFormTemplate[]
  intakeTemplates     IntakeFormTemplate[]
  campaigns           MarketingCampaign[]
  auditLogs           AuditLog[]
  credentials         ProviderCredential[]
  discountCodes       DiscountCode[]
  loyaltySettings     LoyaltySettings?

  @@index([slug])
}

// ─────────────────────────────────────────────
// LOCATION (SINGLE IN V1, MULTI-LOCATION READY)
// ─────────────────────────────────────────────

model Location {
  id           String   @id @default(cuid())
  practiceId   String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice     Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  providers    Provider[]    @relation("ProviderLocations")

  @@index([practiceId])
}

// ─────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────

model Provider {
  id           String   @id @default(cuid())
  practiceId   String
  clerkUserId  String   @unique
  firstName    String
  lastName     String
  email        String
  phone        String?
  role         UserRole @default(PROVIDER)
  title        String?  // NP, PA, MD, etc.
  bio          String?
  avatarUrl    String?
  npiNumber    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice          Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  locations         Location[]          @relation("ProviderLocations")
  appointments      Appointment[]
  treatmentRecords  TreatmentRecord[]
  credentials       ProviderCredential[]
  availability      ProviderAvailability[]
  blockedTimes      BlockedTime[]

  @@index([practiceId])
  @@index([clerkUserId])
}

model StaffMember {
  id           String   @id @default(cuid())
  practiceId   String
  clerkUserId  String   @unique
  firstName    String
  lastName     String
  email        String
  phone        String?
  role         UserRole @default(FRONT_DESK)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice     Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([clerkUserId])
}

model ProviderCredential {
  id           String    @id @default(cuid())
  practiceId   String
  providerId   String
  type         String    // License, DEA, Board Certification, etc.
  number       String?
  state        String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  fileUrl      String?   // S3 reference
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practice     Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([providerId])
  @@index([expiresAt])
}

model ProviderAvailability {
  id          String   @id @default(cuid())
  providerId  String
  dayOfWeek   Int      // 0=Sunday, 6=Saturday
  startTime   String   // "09:00"
  endTime     String   // "17:00"
  isActive    Boolean  @default(true)

  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model BlockedTime {
  id          String   @id @default(cuid())
  providerId  String
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  createdAt   DateTime @default(now())

  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

// ─────────────────────────────────────────────
// CLIENT / PATIENT
// ─────────────────────────────────────────────

model Client {
  id             String    @id @default(cuid())
  practiceId     String
  clerkUserId    String?   @unique  // null if staff-created profile
  firstName      String
  lastName       String
  email          String
  phone          String?
  dateOfBirth    DateTime?
  gender         String?
  addressLine1   String?
  city           String?
  state          String?
  zip            String?
  referralSource String?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  invoices         Invoice[]
  intakeForms      IntakeFormSubmission[]
  consentForms     ConsentFormSubmission[]
  photos           ClientPhoto[]
  loyaltyPoints    LoyaltyPointLog[]
  packagePurchases PackagePurchase[]

  @@unique([practiceId, email])
  @@index([practiceId])
  @@index([clerkUserId])
}

// ─────────────────────────────────────────────
// SCHEDULING
// ─────────────────────────────────────────────

model Service {
  id            String   @id @default(cuid())
  practiceId    String
  name          String
  description   String?
  durationMins  Int      @default(60)
  price         Int      @default(0) // cents
  depositAmount Int?     // cents; null = no deposit required
  isActive      Boolean  @default(true)
  color         String?  @default("#6366f1")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  practice     Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  packages     PackageService[]

  @@index([practiceId])
}

model Appointment {
  id            String            @id @default(cuid())
  practiceId    String
  locationId    String?
  clientId      String
  providerId    String
  serviceId     String
  status        AppointmentStatus @default(SCHEDULED)
  startsAt      DateTime
  endsAt        DateTime
  notes         String?
  cancelReason  String?
  reminderSentAt DateTime?
  confirmedAt   DateTime?
  // Telehealth
  telehealthRoomUrl  String?
  telehealthSessionId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  location         Location?         @relation(fields: [locationId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id])
  provider         Provider          @relation(fields: [providerId], references: [id])
  service          Service           @relation(fields: [serviceId], references: [id])
  treatmentRecord  TreatmentRecord?
  invoiceItems     InvoiceItem[]

  @@index([practiceId])
  @@index([clientId])
  @@index([providerId])
  @@index([startsAt])
}

// ─────────────────────────────────────────────
// CLINICAL CHARTING
// ─────────────────────────────────────────────

model TreatmentRecord {
  id              String   @id @default(cuid())
  practiceId      String
  appointmentId   String   @unique
  clientId        String
  providerId      String
  // SOAP
  subjective      String?
  objective       String?
  assessment      String?
  plan            String?
  // Injection mapping stored as JSON (body diagram annotations)
  injectionMap    Json?
  // Provider e-signature
  signedAt        DateTime?
  signedByName    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  provider        Provider    @relation(fields: [providerId], references: [id])
  photos          ClientPhoto[]

  @@index([practiceId, clientId])
  @@index([providerId])
}

// ─────────────────────────────────────────────
// PHOTOS (BEFORE/AFTER)
// ─────────────────────────────────────────────

model ClientPhoto {
  id                String   @id @default(cuid())
  practiceId        String
  clientId          String
  treatmentRecordId String?
  s3Key             String
  s3Bucket          String
  photoType         String   // "BEFORE" | "AFTER" | "PROGRESS" | "SIMULATION"
  angle             String?  // "FRONT" | "LEFT" | "RIGHT" | "TOP"
  takenAt           DateTime @default(now())
  notes             String?
  createdAt         DateTime @default(now())

  client          Client           @relation(fields: [clientId], references: [id])
  treatmentRecord TreatmentRecord? @relation(fields: [treatmentRecordId], references: [id])

  @@index([practiceId, clientId])
}

// ─────────────────────────────────────────────
// FORMS
// ─────────────────────────────────────────────

model IntakeFormTemplate {
  id          String   @id @default(cuid())
  practiceId  String
  name        String
  description String?
  fields      Json     // FormField[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice    Practice               @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  submissions IntakeFormSubmission[]

  @@index([practiceId])
}

model IntakeFormSubmission {
  id           String   @id @default(cuid())
  practiceId   String
  templateId   String
  clientId     String
  appointmentId String?
  responses    Json
  ipAddress    String?
  deviceInfo   String?
  signedAt     DateTime @default(now())
  pdfS3Key     String?

  template     IntakeFormTemplate @relation(fields: [templateId], references: [id])
  client       Client             @relation(fields: [clientId], references: [id])

  @@index([practiceId, clientId])
}

model ConsentFormTemplate {
  id          String   @id @default(cuid())
  practiceId  String
  name        String
  body        String   // Rich text / HTML
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice    Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  submissions ConsentFormSubmission[]

  @@index([practiceId])
}

model ConsentFormSubmission {
  id            String   @id @default(cuid())
  practiceId    String
  templateId    String
  clientId      String
  appointmentId String?
  signatureData String   // Base64 or S3 reference
  ipAddress     String?
  deviceInfo    String?
  signedAt      DateTime @default(now())
  pdfS3Key      String?

  template      ConsentFormTemplate @relation(fields: [templateId], references: [id])
  client        Client              @relation(fields: [clientId], references: [id])

  @@index([practiceId, clientId])
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model Invoice {
  id                  String        @id @default(cuid())
  practiceId          String
  clientId            String
  invoiceNumber       String
  status              InvoiceStatus @default(DRAFT)
  subtotal            Int           // cents
  discountAmount      Int           @default(0) // cents
  taxAmount           Int           @default(0) // cents
  total               Int           // cents
  amountPaid          Int           @default(0) // cents
  dueDate             DateTime?
  notes               String?
  stripePaymentLinkId String?
  stripePaymentIntentId String?
  discountCodeId      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  practice     Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@unique([practiceId, invoiceNumber])
  @@index([practiceId, clientId])
}

model InvoiceItem {
  id            String  @id @default(cuid())
  invoiceId     String
  appointmentId String?
  description   String
  quantity      Int     @default(1)
  unitPrice     Int     // cents
  total         Int     // cents

  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([invoiceId])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Int           // cents
  method        PaymentMethod
  stripeChargeId String?
  notes         String?
  paidAt        DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// PACKAGES / MEMBERSHIPS / SERIES
// ─────────────────────────────────────────────

model ServicePackage {
  id           String   @id @default(cuid())
  practiceId   String
  name         String
  description  String?
  price        Int      // cents
  validityDays Int?     // null = never expires
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  services     PackageService[]
  purchases    PackagePurchase[]

  @@index([practiceId])
}

model PackageService {
  id          String @id @default(cuid())
  packageId   String
  serviceId   String
  quantity    Int    @default(1)

  package     ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service     Service        @relation(fields: [serviceId], references: [id])

  @@unique([packageId, serviceId])
}

model PackagePurchase {
  id          String    @id @default(cuid())
  practiceId  String
  clientId    String
  packageId   String
  paidAmount  Int       // cents
  redeemedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  client      Client         @relation(fields: [clientId], references: [id])
  package     ServicePackage @relation(fields: [packageId], references: [id])

  @@index([practiceId, clientId])
}

// ─────────────────────────────────────────────
// DISCOUNT CODES
// ─────────────────────────────────────────────

model DiscountCode {
  id              String    @id @default(cuid())
  practiceId      String
  code            String
  description     String?
  discountPercent Int?      // 0-100
  discountAmount  Int?      // cents flat discount
  maxUses         Int?
  useCount        Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  invoices        Invoice[]

  @@unique([practiceId, code])
  @@index([practiceId])
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model InventoryItem {
  id              String    @id @default(cuid())
  practiceId      String
  name            String
  category        String?   // Injectable, Skincare, Supply, etc.
  sku             String?
  unit            String?   // vials, mL, units, boxes
  currentStock    Float     @default(0)
  lowStockThreshold Float?
  costPerUnit     Int?      // cents
  expiresAt       DateTime?
  supplier        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// LOYALTY
// ─────────────────────────────────────────────

model LoyaltySettings {
  id              String  @id @default(cuid())
  practiceId      String  @unique
  pointsPerDollar Float   @default(1.0)
  dollarsPerPoint Float   @default(0.01)
  isActive        Boolean @default(true)

  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model LoyaltyPointLog {
  id          String   @id @default(cuid())
  practiceId  String
  clientId    String
  points      Int      // positive = earned, negative = redeemed
  reason      String
  invoiceId   String?
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id])

  @@index([practiceId, clientId])
}

// ─────────────────────────────────────────────
// MARKETING CAMPAIGNS
// ─────────────────────────────────────────────

model MarketingCampaign {
  id          String          @id @default(cuid())
  practiceId  String
  name        String
  channel     CampaignChannel
  status      CampaignStatus  @default(DRAFT)
  subject     String?         // for email
  body        String
  scheduledAt DateTime?
  sentAt      DateTime?
  recipientCount Int          @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  practice    Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
}

// ─────────────────────────────────────────────
// HIPAA: AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  practiceId  String
  actorId     String   // clerkUserId or "system"
  actorRole   String?
  action      String   // e.g. READ_RECORD, UPDATE_RECORD, DELETE_PHOTO
  resourceType String  // e.g. TreatmentRecord, ClientPhoto
  resourceId  String
  metadata    Json?    // additional context (changed fields, query params)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  // Append-only: no updates, no deletes via Prisma — enforced at app layer
  @@index([practiceId, resourceType, resourceId])
  @@index([practiceId, actorId])
  @@index([createdAt])
}
